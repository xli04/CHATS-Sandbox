{
  "name": "chats-sandbox",
  "version": "0.1.0",
  "description": "General-purpose sandbox plugin for Claude Code — backup, policy, and effect tracking for AI agent tool calls",
  "main": "dist/index.js",
  "bin": {
    "chats-sandbox": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "build:src": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "dev": "tsc --watch",
    "test": "npm run build && node --test dist-test/**/*.test.js",
    "lint": "eslint src/ tests/",
    "check": "npm run lint && npm run test",
    "install-plugin": "node dist/cli.js install",
    "uninstall-plugin": "node dist/cli.js uninstall"
  },
  "keywords": [
    "claude-code",
    "sandbox",
    "backup",
    "hooks",
    "ai-agent"
  ],
  "author": "xli04",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "typescript": "^5.4.0"
  }
}
